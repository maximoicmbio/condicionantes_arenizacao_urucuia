def calc_spei(df, pr_col='pr', tmax_col='Tmax', escalas=[3,6,12,24]):
    df['ETP'] = 0.0023 * (df[tmax_col] + 17.8) * (df[tmax_col] - 0) ** 0.5 * 30
    df['BAL'] = df[pr_col] - df['ETP']
    for esc in escalas:
        bal_acum = df['BAL'].rolling(window=esc, min_periods=esc//2).sum()
        if len(bal_acum.dropna()) > 30:
            df[f'SPEI_{esc}m'] = (bal_acum - bal_acum.mean()) / bal_acum.std()
        else:
            df[f'SPEI_{esc}m'] = np.nan
    return df

