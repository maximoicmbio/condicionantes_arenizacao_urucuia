# Exibir tabela anual (arenização total por ano)
print("\n--- Tabela anual de arenização total (ha/ano) e Niño12 médio ---")
print(anual[['ano', 'arenizacao', 'Niño12']].to_string(index=False))

# Correlação anual (Pearson)
corr_anual = anual[['arenizacao', 'Niño12', 'MEI', 'ONI', 'AMO', 'PDO', 'SPEI_12m', 'GRACE_TWSA', 'desmatamento']].corr()['arenizacao'].drop('arenizacao')
print("\nCorrelação anual com arenização (Pearson):")
for var, r in corr_anual.sort_values(ascending=False).items():
    print(f"  {var:15s}: r = {r:.3f}")

# Regressão linear anual (arenizacao ~ Niño12)
if 'Niño12' in anual.columns:
    X = anual['Niño12'].values.reshape(-1,1)
    y = anual['arenizacao'].values
    reg = LinearRegression().fit(X, y)
    print(f"\nRegressão anual: arenizacao = {reg.coef_[0]:.2f} * Niño12 + {reg.intercept_:.2f}")
    print(f"  R² = {reg.score(X, y):.3f}")

# Bootstrap de anos extremos (Niño12 > 1.0)
anos_extremos = anual[anual['Niño12'] > 1.0]['arenizacao'].values
anos_normais = anual[anual['Niño12'] <= 1.0]['arenizacao'].values
if len(anos_extremos) >= 3 and len(anos_normais) >= 5:
    diff_obs = np.mean(anos_extremos) - np.mean(anos_normais)
    np.random.seed(42)
    n_perm = 10000
    diffs_perm = []
    todas = np.concatenate([anos_extremos, anos_normais])
    n_ext = len(anos_extremos)
    for _ in range(n_perm):
        perm = np.random.permutation(todas)
        diff_perm = np.mean(perm[:n_ext]) - np.mean(perm[n_ext:])
        diffs_perm.append(diff_perm)
    p_valor = np.mean(np.abs(diffs_perm) >= np.abs(diff_obs))
    print(f"\nBootstrap de anos extremos (Niño12 > 1.0):")
    print(f"  Arenização média em anos extremos: {np.mean(anos_extremos):.1f} ha (n={len(anos_extremos)})")
    print(f"  Arenização média em anos normais: {np.mean(anos_normais):.1f} ha (n={len(anos_normais)})")
    print(f"  Diferença observada: {diff_obs:.1f} ha")
    print(f"  p-valor (permutação): {p_valor:.4f} {'*' if p_valor < 0.05 else 'n.s.'}")
else:
    print("\nPoucos anos extremos ou normais para bootstrap.")

