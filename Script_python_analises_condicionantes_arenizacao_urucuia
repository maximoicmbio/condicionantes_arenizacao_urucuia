def pettitt_test(series):
    n = len(series)
    if n < 2:
        return np.nan, np.nan
    U = 0
    k = 0
    for t in range(1, n):
        s = 0
        for i in range(n):
            for j in range(i+1, n):
                if i < t and j >= t:
                    s += np.sign(series[j] - series[i])
        if np.abs(s) > U:
            U = np.abs(s)
            k = t
    p_value = 2 * np.exp((-6 * U**2) / (n**3 + n**2))
    if p_value > 1:
        p_value = 1.0
    return k, p_value

def adf_test(series, name=''):
    result = adfuller(series.dropna(), autolag='AIC')
    return {'variável': name, 'p-valor': result[1], 'estacionária': result[1] < 0.05}

def mann_kendall(series):
    from scipy.stats import kendalltau
    tau, p = kendalltau(np.arange(len(series)), series)
    return {'tau': tau, 'p-valor': p, 'tendencia': p < 0.05}

def threshold_global(X, y, n_min=30, max_ds=20):
    X = np.clip(X, 0, max_ds)
    X_sorted = np.sort(X)
    lower, upper = np.percentile(X_sorted, 10), np.percentile(X_sorted, 90)
    X_cand = X_sorted[(X_sorted >= lower) & (X_sorted <= upper)]
    best_thresh, best_mse = None, np.inf
    for thresh in X_cand:
        if np.sum(X <= thresh) < n_min or np.sum(X > thresh) < n_min:
            continue
        low_idx = X <= thresh
        high_idx = X > thresh
        if np.sum(low_idx) < 2 or np.sum(high_idx) < 2:
            continue
        reg_low = LinearRegression().fit(X[low_idx].reshape(-1,1), y[low_idx])
        reg_high = LinearRegression().fit(X[high_idx].reshape(-1,1), y[high_idx])
        pred_low = reg_low.predict(X[low_idx].reshape(-1,1)).flatten()
        pred_high = reg_high.predict(X[high_idx].reshape(-1,1)).flatten()
        mse = np.mean((y[low_idx] - pred_low)**2) + np.mean((y[high_idx] - pred_high)**2)
        if mse < best_mse:
            best_mse, best_thresh = mse, thresh
    return best_thresh

def analise_sincronia(df, var1, var2, max_lag=24):
    df_pair = df[[var1, var2]].dropna()
    if len(df_pair) < 30:
        return None
    x = (df_pair[var1] - df_pair[var1].mean()) / df_pair[var1].std()
    y = (df_pair[var2] - df_pair[var2].mean()) / df_pair[var2].std()
    corr = correlate(x, y, mode='full')
    lags = np.arange(-len(x)+1, len(x))
    mask = (lags >= -max_lag) & (lags <= max_lag)
    corr = corr[mask] / len(x)
    lags = lags[mask]
    idx_max = np.argmax(np.abs(corr))
    return {'lag': int(lags[idx_max]), 'corr': corr[idx_max]}

def fft_periodos(series, dt=1):
    sinal = detrend(series.dropna().values)
    from scipy.fft import fft, fftfreq
    N = len(sinal)
    yf = fft(sinal)
    xf = fftfreq(N, dt)[:N//2]
    potencia = 2.0/N * np.abs(yf[0:N//2])
    periodos = 1 / xf[1:]
    potencia_periodos = potencia[1:]
    idx_top = np.argsort(potencia_periodos)[-3:][::-1]
    return [(periodos[i], potencia_periodos[i]) for i in idx_top if periodos[i] <= 120]

